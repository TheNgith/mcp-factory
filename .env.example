# Copy this file to .env and fill in your credentials.
# Then load it before starting the server:
#   $env:OPENAI_API_KEY = "sk-..."   (PowerShell)
#   or: Get-Content .env | ForEach-Object { if ($_ -match '^([^#=]+)=(.*)') { [System.Environment]::SetEnvironmentVariable($Matches[1].Trim(), $Matches[2].Trim()) } }

# ── Direct OpenAI (takes priority over Azure when set) ────────────────────
OPENAI_API_KEY=sk-...

# Model for interactive chat (default: gpt-4o)
OPENAI_MODEL=gpt-4o

# Model for the explore/discovery loop — gpt-4o-mini is ~15x cheaper and
# good enough for parameter probing. Each full 13-function explore costs ~$0.05.
OPENAI_EXPLORE_MODEL=gpt-4o-mini

# ── Azure OpenAI (used only when OPENAI_API_KEY is NOT set) ───────────────
# AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com
# AZURE_OPENAI_DEPLOYMENT=gpt-4o
# AZURE_OPENAI_REASONING_DEPLOYMENT=gpt-4o

# ── Azure Storage (required for job state + artifact blobs) ───────────────
AZURE_STORAGE_ACCOUNT=mcpfactorystore

# ── Windows DLL bridge (required for DLL/GUI tool execution) ──────────────
GUI_BRIDGE_URL=http://localhost:8090
GUI_BRIDGE_SECRET=your-bridge-secret-here
