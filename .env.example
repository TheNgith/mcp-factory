# Copy this file to .env and fill in your credentials.
# Then load it before starting the server:
#   $env:OPENAI_API_KEY = "sk-..."   (PowerShell)
#   or: Get-Content .env | ForEach-Object { if ($_ -match '^([^#=]+)=(.*)') { [System.Environment]::SetEnvironmentVariable($Matches[1].Trim(), $Matches[2].Trim()) } }

# ── Direct OpenAI (takes priority over Azure when set) ────────────────────
OPENAI_API_KEY=sk-...

# Model for interactive chat (default: gpt-4o).
# Set OPENAI_CHAT_MODEL=gpt-4o-mini to cut chat costs ~15x — good for dev/testing.
OPENAI_MODEL=gpt-4o
# OPENAI_CHAT_MODEL=gpt-4o-mini   # ← uncomment to save $$ on chat calls

# Model for the explore/discovery loop — gpt-4o-mini is ~15x cheaper and
# good enough for parameter probing. Each full 13-function explore costs ~$0.03.
OPENAI_EXPLORE_MODEL=gpt-4o-mini

# ── Explore speed/quality switches ─────────────────────────────────────────
# Profiles: dev (fast), stabilize (balanced), deploy (deepest)
# EXPLORE_CAP_PROFILE=dev
# Optional explicit overrides:
# EXPLORE_MAX_ROUNDS=3
# EXPLORE_MAX_TOOL_CALLS=5
# EXPLORE_MAX_FUNCTIONS=50
#
# Gap-resolution and clarification mini-sessions are expensive. Keep enabled for
# quality validation runs; disable for rapid dev iteration loops.
# EXPLORE_ENABLE_GAP_RESOLUTION=0
# Sticky sentinel baseline is deferred and disabled by default. Enable only for
# local diagnostics once component-scoped baseline storage is wired.
# EXPLORE_ENABLE_STICKY_SENTINEL_BASELINE=0

# ── Azure OpenAI (used only when OPENAI_API_KEY is NOT set) ───────────────
# AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com
# AZURE_OPENAI_DEPLOYMENT=gpt-4o
# AZURE_OPENAI_REASONING_DEPLOYMENT=gpt-4o

# ── Azure Storage (required for job state + artifact blobs) ───────────────
AZURE_STORAGE_ACCOUNT=mcpfactorystore

# ── Windows DLL bridge (required for DLL/GUI tool execution) ──────────────
GUI_BRIDGE_URL=http://localhost:8090
GUI_BRIDGE_SECRET=your-bridge-secret-here
